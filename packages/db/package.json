{
  "name": "@app/db",
  "version": "1.0.0",
  "private": true,
  "description": "App Lattice Database Library",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./index.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "db:check": "npx tsx src/check-db.ts",
    "db:clean": "npx tsx src/db-clean.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:qrs": "tsx src/generate-qrs.ts",
    "db:seed": "tsx src/seed-master.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run"
  },
  "dependencies": {
    "@app/core": "workspace:^",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.11.5",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.12.0",
    "@types/node": "^20.11.24",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.6",
    "drizzle-kit": "^0.31.9",
    "testcontainers": "^11.12.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
