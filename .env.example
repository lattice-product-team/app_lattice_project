# ==========================================
# LATTICE MONOREPO ENVIRONMENT CONFIGURATION
# ==========================================

# --- GENERAL SETTINGS ---
NODE_ENV=development

# --- SECURITY ---
# JWT_SECRET: Cualquier string largo y aleatorio. 
# En prod: Generar con `openssl rand -base64 32`
JWT_SECRET=your_super_secure_production_secret
BCRYPT_ROUNDS=10

# --- NETWORKING (DYNAMIC HOSTS & PORTS) ---
# LOCAL: Use 'localhost'
# MOBILE DEV: Set your computer's LAN IP (e.g., 192.168.1.XX)
# DOCKER: Use service names
LAN_IP=localhost
GATEWAY_PORT=3000
API_PORT=3000

# --- DATABASE ---
# DB_PORT: 5432 por defecto en Docker, 5433 si usas el mapeo local del proyecto
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=lattice_db
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# --- REDIS ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# --- MOBILE APP (EXPO) ---
# API_URL: URL base para que la App móvil encuentre el backend.
API_URL=http://${LAN_IP}:${GATEWAY_PORT}/api/v1

# --- GOOGLE AUTH (Google Cloud Console) ---
# Cómo obtener: Ve a Google Cloud Console -> APIs & Services -> Credentials
# Necesitas crear un OAuth Client ID para cada plataforma.
GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id.apps.googleusercontent.com

# --- EXTERNAL SERVICES ---
# DATAFORSEO: Usado para enriquecimiento de datos geográficos.
# Cómo obtener: Regístrate en https://dataforseo.com/
DATAFORSEO_LOGIN=your_email@example.com
DATAFORSEO_PASSWORD=your_api_password

# --- ADMIN DASHBOARD ---
ADMIN_WEB_PORT=3004
NEXT_PUBLIC_API_URL=http://localhost:${GATEWAY_PORT}/v1

# --- ADMIN DASHBOARD AUTH ---
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=Password1@
