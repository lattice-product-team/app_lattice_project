# ==========================================
# LATTICE MONOREPO ENVIRONMENT CONFIGURATION
# ==========================================

# --- GENERAL SETTINGS ---
NODE_ENV=development

# --- SECURITY ---
# Change these for production!
JWT_SECRET=your_super_secure_production_secret

# --- NETWORKING (DYNAMIC HOSTS & PORTS) ---
# LOCAL: Use 'localhost'
# DOCKER DEV: Use service names (auth, geo, etc.)
# PRODUCTION: Use container names (lattice_auth, etc.)

GATEWAY_HOST=localhost
GATEWAY_PORT=3000

AUTH_HOST=localhost
AUTH_PORT=3001

GEO_HOST=localhost
GEO_PORT=3002

SOCIAL_HOST=localhost
SOCIAL_PORT=3003

# --- DATABASE ---
# Shared by Auth, Geo, Social
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=lattice_db
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# --- REDIS ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# --- EXTERNAL SERVICES ---
# API Proxy for external data
EXTERNAL_API_URL=https://api-qa.circuit-copilot.com

# --- MOBILE APP (EXPO) ---
# These will be synced to apps/mobile/.env with EXPO_PUBLIC_ prefix
# For local dev with physical device, change GATEWAY_HOST to your local IP
API_URL=http://${GATEWAY_HOST}:${GATEWAY_PORT}/api/v1
