# ==========================================
# LATTICE CONFIGURATION TEMPLATE (.env.example)
# ==========================================
# Copy this file to .env or .env.production and fill in the values.

# --- ENVIRONMENT CONTROL ---
NODE_ENV=development # development | production

# --- SECURITY ---
# Secret key for JWT token generation. Use a long, random string.
JWT_SECRET=your_jwt_secret_here

# --- NETWORKING ---
# Your computer's LAN IP for mobile development (e.g., 192.168.1.XX)
LAN_IP=127.0.0.1
# Gateway port for the API (default: 3000)
GATEWAY_PORT=3000
# Full URL to the API (e.g., https://api.yourdomain.com/api/v1)
API_URL=http://${LAN_IP}:${GATEWAY_PORT}/api/v1

# --- DATABASE ---
# Connection string (e.g., postgres://user:pass@host:port/dbname)
DATABASE_URL=postgres://postgres:password@localhost:5433/lattice_db

# --- REDIS ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# --- EXTERNAL SERVICES ---
# DataForSEO API Credentials
DATAFORSEO_LOGIN=your_email@example.com
DATAFORSEO_PASSWORD=your_dataforseo_password

# MapTiler API Key for maps
MAPTILER_KEY=your_maptiler_key_here

# --- OAUTH ---
# Google OAuth Client IDs (get these from Google Cloud Console)
GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id
GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id

# --- ADMIN DEFAULTS ---
# Initial credentials for the admin dashboard
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=strong_password_here
