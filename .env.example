# ==========================================
# LATTICE MONOREPO ENVIRONMENT CONFIGURATION
# ==========================================

# --- GENERAL SETTINGS ---
NODE_ENV=development

# --- SECURITY ---
# Change these for production!
JWT_SECRET=your_super_secure_production_secret

# --- NETWORKING (DYNAMIC HOSTS & PORTS) ---
# LOCAL: Use 'localhost'
# MOBILE DEV: Set your computer's LAN IP (e.g., 192.168.1.XX)
# DOCKER DEV: Use service names (auth, geo, etc.)

LAN_IP=localhost
GATEWAY_HOST=localhost
GATEWAY_PORT=3000

AUTH_HOST=localhost
AUTH_PORT=3001

GEO_HOST=localhost
GEO_PORT=3002

SOCIAL_HOST=localhost
SOCIAL_PORT=3003

# --- DATABASE ---
# Shared by Auth, Geo, Social
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=lattice_db
DATABASE_URL=postgres://postgres:password@localhost:5433/lattice_db

# --- REDIS ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# --- MOBILE APP (EXPO) ---
# API_URL is for the Mobile App to find the Backend.
# We use LAN_IP here so you only have to change one variable for physical device testing.
API_URL=http://${LAN_IP}:${GATEWAY_PORT}/api/v1
