# ==========================================
# LATTICE MONOREPO ENVIRONMENT CONFIGURATION
# ==========================================

# --- GENERAL SETTINGS ---
NODE_ENV=development

# --- SECURITY ---
# Change these for production!
JWT_SECRET=your_super_secure_production_secret
BCRYPT_ROUNDS=10

# --- NETWORKING (DYNAMIC HOSTS & PORTS) ---
# LOCAL: Use 'localhost'
# MOBILE DEV: Set your computer's LAN IP (e.g., 192.168.1.XX)
# DOCKER: Use 'api' as host inside containers

LAN_IP=localhost
API_PORT=3000
API_BASE_PATH=/

# --- DATABASE ---
# Shared by the API Monolith
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=lattice_db
DATABASE_URL=postgres://postgres:password@localhost:5433/lattice_db

# --- REDIS ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# --- MOBILE APP (EXPO) ---
# API_URL is for the Mobile App to find the Backend.
API_URL=http://${LAN_IP}:${API_PORT}/v1

# --- ADMIN DASHBOARD ---
ADMIN_WEB_PORT=3004
NEXT_PUBLIC_API_URL=http://localhost:${API_PORT}/v1
