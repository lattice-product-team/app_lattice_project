{
  "name": "@app/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "App Lattice: Fullstack project with Express, Expo, and PostgreSQL",
  "author": "Kore",
  "license": "MIT",
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "apps/*",
    "apps/server/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "pnpm --filter @app/api dev",
    "dev:web": "pnpm --filter admin-web dev",
    "dev:docs": "pnpm --filter docs dev",
    "dev:mobile": "pnpm --filter @app/mobile dev",
    "dev:mobile:lan": "pnpm --filter @app/mobile dev:lan",
    "dev:mobile:tunnel": "pnpm --filter @app/mobile dev:tunnel",
    "dev:android": "pnpm --filter @app/mobile android:device",
    "dev:android:prod": "NODE_ENV=production pnpm dev:android",
    "dev:ios": "pnpm --filter @app/mobile ios:device",
    "build": "turbo build",
    "build:mobile:cloud": "NODE_ENV=production cd apps/mobile && eas build --platform android --profile production",
    "build:mobile:local": "NODE_ENV=production cd apps/mobile && npx expo run:android --variant release",
    "build:mobile:preview": "NODE_ENV=production cd apps/mobile && npx expo prebuild --clean && cd android && ./gradlew assembleRelease",
    "db:migrate": "turbo run db:migrate",
    "db:generate": "turbo run db:generate",
    "db:seed": "turbo run db:seed",
    "db:studio": "turbo run db:studio",
    "db:check": "npx tsx scripts/check-db.ts",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "clean": "rm -rf node_modules && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && find . -name '.turbo' -type d -prune -exec rm -rf '{}' + && find . -name 'build' -type d -prune -exec rm -rf '{}' + && pnpm install"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "eslint-config-expo": "^8.0.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.7.0",
    "lucide-react-native": "^0.575.0",
    "pg": "^8.11.5",
    "prettier": "^3.8.1",
    "supertest": "^7.0.0",
    "turbo": "^2.4.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@headlessui/react": "2.1.0",
      "expo": "~54.0.34",
      "react-native": "0.81.5",
      "metro": "0.83.3",
      "metro-core": "0.83.3",
      "metro-file-map": "0.83.3",
      "metro-config": "0.83.3",
      "metro-runtime": "0.83.3",
      "metro-resolver": "0.83.3",
      "metro-cache": "0.83.3",
      "metro-cache-key": "0.83.3",
      "metro-minify-terser": "0.83.3",
      "metro-source-map": "0.83.3",
      "metro-transform-plugins": "0.83.3",
      "metro-transform-worker": "0.83.3"
    }
  },
  "overrides": {
    "eslint-plugin-react-hooks": "^5.2.0",
    "expo": "~54.0.34",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "dependencies": {
    "@heroui/react": "^3.0.3",
    "@heroui/styles": "^3.0.3",
    "expo": "~54.0.34",
    "lucide-react": "^1.14.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "unist-util-generated": "^2.0.1",
    "mdast-util-to-hast": "^13.2.0"
  }
}
