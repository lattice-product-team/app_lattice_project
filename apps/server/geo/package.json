{
  "name": "@app/geo",
  "version": "1.0.0",
  "description": "App Lattice Geo Service",
  "main": "./dist/index.js",
  "types": "./index.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./index.ts",
      "default": "./dist/index.js"
    },
    "./routes/*": {
      "import": "./dist/routes/*.js",
      "types": "./routes/*.ts",
      "default": "./dist/routes/*.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch index.ts",
    "lint": "eslint \"**/*.ts\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@app/core": "workspace:*",
    "@app/db": "workspace:*",
    "@app/types-schema": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
