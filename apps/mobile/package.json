{
  "name": "@app/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:lan": "expo start --host lan",
    "dev:tunnel": "expo start --tunnel",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "android": "expo run:android",
    "android:device": "expo run:android --device",
    "pods": "cd ios && pod install && cd ..",
    "lint": "expo lint",
    "test": "npm run test:logic && npm run test:components",
    "test:components": "jest --passWithNoTests",
    "test:logic": "vitest run",
    "eas-build-pre-install": "corepack enable && corepack prepare pnpm@10.0.0 --activate"
  },
