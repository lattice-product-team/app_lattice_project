{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@app/core": ["./packages/core/index.ts"],
      "@app/db": ["./packages/db/index.ts"],
      "@app/types-schema": ["./packages/types-schema/index.ts"]
    }
  }
}
